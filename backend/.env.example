NODE_ENV=production
PORT=3001
# Railway: mount a volume at /data to persist the DB across deployments
DB_PATH=/data/career-ops.db
JWT_SECRET=replace-with-a-long-random-secret
# Set to your Vercel frontend URL after deploying (e.g. https://career-ops.vercel.app)
ALLOWED_ORIGIN=https://your-app.vercel.app
# Optional: Anthropic API key for full AI-powered evaluation
ANTHROPIC_API_KEY=
